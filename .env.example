# Beispiel-Umgebungsvariablen. Kopieren nach `.env.local` und Wert setzen:
#   cp .env.example .env.local
#
# Passwort für den Admin-Bereich (/admin).
# Bei Vercel unter Settings → Environment Variables mit demselben Namen anlegen.
# Hinweis: VITE_-Variablen landen im Client-Bundle und sind kein echter Schutz.
VITE_ADMIN_PASSWORD=dein-passwort-hier
