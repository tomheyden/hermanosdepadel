# Beispiel-Umgebungsvariablen. Kopieren nach `.env.local` und Werte setzen:
#   cp .env.example .env.local
# Dieselben Keys bei Vercel unter Settings → Environment Variables anlegen.

# Supabase (geteilte Datenbank + echter Admin-Login). Beide Werte dürfen im
# Frontend stehen (anon key ist öffentlich; geschützt wird über RLS-Policies).
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# Fallback-Passwort, falls KEIN Supabase konfiguriert ist (rein lokaler Modus).
VITE_ADMIN_PASSWORD=dein-passwort-hier
